# Adaptive Traffic Flow Management System - Environment Configuration

# Database Configuration
DATABASE_URL=postgresql+asyncpg://traffic_user:traffic_password@localhost:5432/traffic_db
POSTGRES_USER=traffic_user
POSTGRES_PASSWORD=traffic_password
POSTGRES_DB=traffic_db

# Redis Configuration
REDIS_URL=redis://localhost:6379

# SUMO Configuration
SUMO_HOME=/usr/share/sumo
SUMO_CONFIG_PATH=./simulation/configs

# Model Paths
YOLO_MODEL_PATH=yolov8n.pt
LSTM_MODEL_PATH=./models/lstm_traffic.pth
RL_MODEL_PATH=./models/q_learning_agent.json

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Detection Settings
YOLO_CONFIDENCE_THRESHOLD=0.25
YOLO_INPUT_SIZE=640
ENABLE_GPU=True

# LSTM Settings
SEQUENCE_LENGTH=15
PREDICTION_HORIZON=5

# Q-Learning Settings
LEARNING_RATE=0.1
DISCOUNT_FACTOR=0.9
EPSILON=0.1

# Signal Timing (seconds)
MIN_GREEN_TIME=10
MAX_GREEN_TIME=60
YELLOW_TIME=3
ALL_RED_TIME=2

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/traffic_system.log

# Video Source (camera, file, rtsp)
VIDEO_SOURCE=camera
VIDEO_PATH=
RTSP_URL=

# Data Collection
DATA_LOG_INTERVAL=5
ENABLE_DATA_LOGGING=True
